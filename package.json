{
  "name": "authn-authz-with-mcps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prototyping authentication and authorization with MCP servers.",
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "dev": "node --watch backend/server.ts",
    "start": "node backend/server.ts",
    "agent": "node agent/agent.ts",
    "ui": "yarn workspace ui dev",
    "ui:build": "yarn workspace ui build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "ethers": "^6.13.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "siwe": "^2.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
